---
import Button from './Button.astro';
---

<section id="get-started" class="bg-navy-900 px-6 pt-16 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col items-start justify-between gap-8 border-b border-white/10 pb-14 lg:flex-row lg:items-center">
      <h2 class="max-w-md text-2xl font-bold leading-snug text-white sm:text-3xl">
        Get the latest HR news, articles, and resources in your inbox weekly.
      </h2>
      <div class="w-full max-w-md">
        <form action="#" method="post" class="flex gap-2">
          <label for="news-email" class="sr-only">Your email</label>
          <input
            id="news-email"
            type="email"
            name="email"
            placeholder="Your Email..."
            required
            class="min-w-0 flex-1 rounded-lg border border-white/20 bg-white px-4 py-2.5 text-sm text-navy-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
          <button type="submit" class="shrink-0 rounded-lg bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-700">
            Subscribe
          </button>
        </form>
        <p class="mt-3 text-xs text-slate-400">
          Your data is in safe hands, and we won't spam you. Read our
          <a href="#privacy" class="text-amber underline">Privacy policy</a> to learn how we keep your data safe.
        </p>
      </div>
    </div>

    <div class="relative overflow-hidden py-24 text-center">
      <img
        src="/assets/cta-rings.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-1/2 w-[1280px] max-w-none -translate-x-1/2 -translate-y-1/2"
      />
      <div class="relative">
        <h2 class="text-4xl font-extrabold leading-tight text-amber sm:text-5xl">
          Work Made Simple,<br />Lives Made Better
        </h2>
        <div class="mt-8">
          <Button href="#get-started" size="lg" withArrow>Book a Demo</Button>
        </div>
      </div>
    </div>
  </div>
</section>
