---
import Logo from './Logo.astro';

const columns = {
  Platform: ['Payroll', 'Pension & Tax Remittance', 'HR Tools & Workflows', 'Employee Benefits', 'PaidHiring'],
  Resources: ['Blogs & Articles', 'Webinar & Events', 'Help Center', 'Referral Program'],
  Company: ['About', 'Careers', 'Press', 'Contact'],
};

const social = [
  { name: 'X', path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { name: 'LinkedIn', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452z' },
  { name: 'Instagram', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.332.014 7.052.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' },
];
---

<footer class="bg-navy-900 px-6 pb-10 pt-16 text-slate-400 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-12 lg:grid-cols-[1.3fr_2fr]">
      <div>
        <Logo variant="light" />
        <p class="mt-5 text-sm">With HR Junkie, everything <span class="text-amber font-semibold">GET</span>s fulfilled</p>
        <ul class="mt-5 flex gap-3">
          {social.map((item) => (
            <li>
              <a
                href="#"
                class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-slate-200 transition hover:bg-brand-600 hover:text-white"
                aria-label={item.name}
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d={item.path} />
                </svg>
              </a>
            </li>
          ))}
        </ul>
        <address class="mt-6 text-sm not-italic leading-relaxed text-slate-400">
          13 Ore Close, Surulere, Lagos.<br />
          Email: hello@hrjunkie.com<br />
          Phone number: +234 70 712 52633
        </address>
        <div class="mt-6 inline-flex items-center gap-3 rounded-lg bg-white p-3">
          <img src="/assets/ndpr-badge.webp" alt="NDPR Audit Compliant — PADE HCM Technology Limited" class="h-20 w-auto object-contain" width="112" height="114" loading="lazy" decoding="async" />
        </div>
      </div>

      <div class="grid gap-8 sm:grid-cols-3">
        {Object.entries(columns).map(([category, links]) => (
          <div>
            <h3 class="text-sm font-semibold text-amber">{category}</h3>
            <ul class="mt-4 space-y-3">
              {links.map((link) => (
                <li>
                  <a href="#" class="text-sm text-slate-300 transition hover:text-white">{link}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-6 sm:flex-row">
      <p class="text-xs text-slate-500">&copy; Copyright {new Date().getFullYear()}. All Rights Reserved.</p>
      <ul class="flex flex-wrap gap-5 text-xs text-slate-400">
        <li><a href="#" class="hover:text-white">Data Processing Agreement</a></li>
        <li><a href="#" class="hover:text-white">Privacy Policy</a></li>
        <li><a href="#" class="hover:text-white">Terms and Conditions</a></li>
      </ul>
    </div>
  </div>
</footer>
