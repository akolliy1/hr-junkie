---
import Logo from './Logo.astro';
import Button from './Button.astro';

const navLinks = [
  { label: 'Platform', href: '#platform', dropdown: true },
  { label: 'Customers', href: '#customers', dropdown: false },
  { label: 'Pricing', href: '#pricing', dropdown: false },
  { label: 'Resources', href: '#resources', dropdown: true },
  { label: 'Company', href: '#company', dropdown: true },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/95 backdrop-blur">
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-3.5 lg:px-8"
    aria-label="Main navigation"
  >
    <Logo class="shrink-0" />

    <ul class="hidden items-center gap-7 lg:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="inline-flex items-center gap-1 text-[15px] font-medium text-slate-600 transition-colors hover:text-brand-600"
          >
            {link.label}
            {link.dropdown && (
              <svg class="h-3.5 w-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a href="#support" class="hidden items-center gap-1 text-[15px] font-medium text-slate-600 hover:text-brand-600 md:inline-flex">
        Support
      </a>
      <a
        href="#login"
        class="hidden rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-navy-900 transition hover:border-brand-600 hover:text-brand-600 sm:inline-block"
      >
        Login
      </a>
      <Button href="#get-started" size="md">Get started today</Button>
    </div>
  </nav>
</header>
