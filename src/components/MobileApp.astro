---
import SectionHeading from './SectionHeading.astro';

const phones = [
  { img: '/assets/phones/withdraw.webp', caption: 'Withdraw your earned wage seamlessly, anytime.' },
  { img: '/assets/phones/payslip.webp', caption: 'View and Download your monthly payslips.' },
  { img: '/assets/phones/leave.webp', caption: 'Request Leave, Upload Documents, etc.' },
];
---

<section class="bg-white px-6 py-20 lg:px-8 lg:py-24">
  <div class="mx-auto max-w-7xl">
    <SectionHeading
      eyebrow="HR Junkie on the go"
      title='Take HR Junkie with you, <span class="text-brand">everywhere</span> you go'
    />

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a href="#app-store" aria-label="Download on the App Store">
        <img src="/assets/phones/ios.svg" alt="Download on the App Store" class="h-12 w-auto" />
      </a>
      <a href="#google-play" aria-label="Get it on Google Play">
        <img src="/assets/phones/android.svg" alt="Get it on Google Play" class="h-12 w-auto" />
      </a>
    </div>

    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      {phones.map((phone) => (
        <div class="flex flex-col items-center">
          <img src={phone.img} alt="" class="w-full max-w-xs" loading="lazy" decoding="async" />
          <p class="mt-5 max-w-[14rem] text-center text-sm font-medium text-brand-600">{phone.caption}</p>
        </div>
      ))}
    </div>
  </div>
</section>
